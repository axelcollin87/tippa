generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String              @id @default(uuid())
  email           String              @unique
  name            String
  password        String              // Hashed password
  isAdmin         Boolean             @default(false)
  isApproved      Boolean             @default(false) // Måste godkännas av Admin
  matchBets       MatchBet[]
  groupPlacements GroupPlacementBet[]
  totalScore      Float               @default(0) 
  createdAt       DateTime            @default(now())
}

model Match {
  id          String     @id @default(uuid())
  stage       String     
  groupName   String?
  homeTeam    String
  awayTeam    String
  kickoff     DateTime
  ground      String?
  homeScore   Int?       
  awayScore   Int?
  actualSign  String?    
  isCompleted Boolean    @default(false)
  bets        MatchBet[]
}

model MatchBet {
  id            String   @id @default(uuid())
  userId        String
  matchId       String
  predictedSign String   
  pointsAwarded Float    @default(0) 
  user          User     @relation(fields: [userId], references: [id])
  match         Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model GroupPlacementBet {
  id            String @id @default(uuid())
  userId        String
  groupName     String 
  teamName      String
  predictedRank Int
  pointsAwarded Float    @default(0) 
  user          User   @relation(fields: [userId], references: [id])

  @@unique([userId, groupName, teamName])
}

model GlobalConfig {
  id               String   @id @default("global")
  groupStageLocked Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}